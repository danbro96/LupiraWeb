@page "/admin/artifacts/{id:guid}"
@model EditModel
@{
    ViewData["Title"] = $"Edit {Model.Artifact?.Title}";
}

<header class="toolbar">
    <hgroup>
        <h1>@Model.Artifact?.Title</h1>
        <p><a href="@Model.Artifact?.Url" target="_blank" rel="noopener">@Model.Artifact?.Url</a> · @Model.Artifact?.Kind</p>
    </hgroup>
    <a href="/admin/artifacts" role="button" class="secondary">Back</a>
</header>

@if (Model.Saved)
{
    <p role="status"><mark>Saved.</mark></p>
}

<h2>Linked projects</h2>
<ul>
    @foreach (var pid in Model.Artifact?.LinkedProjectIds ?? new List<Guid>())
    {
        <li>@(Model.ProjectsById.TryGetValue(pid, out var p) ? p.Title : pid.ToString())</li>
    }
</ul>
<form method="post" asp-page-handler="LinkProject">
    <label>
        Add project link
        <select name="projectId" required>
            <option value="">— Select project —</option>
            @foreach (var p in Model.Projects)
            {
                <option value="@p.Id">@p.Title</option>
            }
        </select>
    </label>
    <button type="submit">Link to project</button>
</form>

<h2 style="margin-top: 2rem;">Linked engagements</h2>
<ul>
    @foreach (var eid in Model.Artifact?.LinkedEngagementIds ?? new List<Guid>())
    {
        <li>@(Model.EngagementsById.TryGetValue(eid, out var e) ? e.Institution : eid.ToString())</li>
    }
</ul>
<form method="post" asp-page-handler="LinkEngagement">
    <label>
        Add engagement link
        <select name="engagementId" required>
            <option value="">— Select engagement —</option>
            @foreach (var e in Model.Engagements)
            {
                <option value="@e.Id">@e.Institution</option>
            }
        </select>
    </label>
    <button type="submit">Link to engagement</button>
</form>

<h2 style="margin-top: 2rem;">Linked skills</h2>
<ul>
    @foreach (var link in Model.Artifact?.LinkedSkills ?? new List<ArtifactSkillLink>())
    {
        <li>
            @(Model.SkillsById.TryGetValue(link.SkillId, out var s) ? s.Name : link.SkillId.ToString())
            <small>(@link.Role)</small>
        </li>
    }
</ul>
<form method="post" asp-page-handler="LinkSkill">
    <div class="grid">
        <label>
            Skill
            <select name="skillId" required>
                <option value="">— Select skill —</option>
                @foreach (var s in Model.Skills)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            </select>
        </label>
        <label>
            Role
            <select name="role" asp-items="Html.GetEnumSelectList<ArtifactRole>()"></select>
        </label>
    </div>
    <button type="submit">Link to skill</button>
</form>
