# TrueNAS App "lupira-web" — populate these in the App's env section.
# POSTGRES_* must match the role provisioned on `medelynas-db`
# (see docs/CICD.md Section 2).

# Database — credentials of the `lupira` role on the platform `medelynas-db`.
POSTGRES_DB=lupiraweb
POSTGRES_USER=lupira
POSTGRES_PASSWORD=change-me
# Hostname of the postgres service on the medelynas_data network.
# This is the service name inside `medelynas-db`'s compose (`postgres`).
POSTGRES_HOST=postgres

# Image tag to run. `latest` tracks main. For rollback, pin to sha-<short>.
IMAGE_TAG=latest

# Host ports published on the TrueNAS box (your reverse proxy targets these).
FRONTEND_PORT=40080
BACKEND_PORT=40081

# OpenTelemetry — exports traces, metrics, logs to the platform OpenObserve collector.
# Leave OTEL_EXPORTER_OTLP_ENDPOINT blank to silence telemetry locally.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:5080/api/default
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OpenObserve OSS requires authenticated ingestion. Generate the value via:
#   echo -n "<openobserve-admin-email>:<openobserve-admin-password>" | base64
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64>
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=prod,host.name=medelynas
