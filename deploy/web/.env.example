# TrueNAS App "lupira-web" — populate these in the App's env section.
# POSTGRES_* must match what the "lupira-db" App is configured with.

# Database (must match the lupira-db App)
POSTGRES_DB=lupiraweb
POSTGRES_USER=lupira
POSTGRES_PASSWORD=change-me
# Hostname of the postgres service on the lupira_data network.
# Default matches the service name in deploy/db/compose.yaml.
POSTGRES_HOST=postgres

# Image tag to run. `latest` tracks main. For rollback, pin to sha-<short>.
IMAGE_TAG=latest

# Host ports published on the TrueNAS box (your reverse proxy targets these).
FRONTEND_PORT=40080
BACKEND_PORT=40081
