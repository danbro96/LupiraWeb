# TrueNAS App "lupira-admin" — populate these in the App's env section.
# POSTGRES_* must match the role provisioned on `medelynas-db` (also used by lupira-web).

POSTGRES_DB=lupiraweb
POSTGRES_USER=lupiraweb_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres

# Image tag. `latest` tracks main; pin to sha-<short> for rollback.
IMAGE_TAG=latest

# Host port the reverse proxy (or LAN/VPN) targets.
ADMIN_BACKEND_PORT=40082

# OpenTelemetry — exports traces, metrics, logs to the platform OpenObserve collector.
# Leave OTEL_EXPORTER_OTLP_ENDPOINT blank to silence telemetry locally.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:5080/api/default
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OpenObserve OSS requires authenticated ingestion. Generate the value via:
#   echo -n "<openobserve-admin-email>:<openobserve-admin-password>" | base64
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64>
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=prod,host.name=medelynas
