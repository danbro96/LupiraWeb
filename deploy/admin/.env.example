# TrueNAS App "lupira-admin" — populate these in the App's env section.
# POSTGRES_* must match the lupira-db App (and the lupira-web App).

POSTGRES_DB=lupiraweb
POSTGRES_USER=lupira
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres

# Image tag. `latest` tracks main; pin to sha-<short> for rollback.
IMAGE_TAG=latest

# Host port the reverse proxy (or LAN/VPN) targets.
ADMIN_BACKEND_PORT=40082
