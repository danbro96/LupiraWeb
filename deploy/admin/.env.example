# TrueNAS App "lupira-admin" — populate these in the App's env section.
# POSTGRES_* must match the role provisioned on `medelynas-db` (also used by lupira-web).

POSTGRES_DB=lupiraweb
POSTGRES_USER=lupira
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres

# Image tag. `latest` tracks main; pin to sha-<short> for rollback.
IMAGE_TAG=latest

# Host port the reverse proxy (or LAN/VPN) targets.
ADMIN_BACKEND_PORT=40082

# OpenTelemetry — exports traces, metrics, logs to the platform SigNoz collector.
# Leave OTEL_EXPORTER_OTLP_ENDPOINT blank to silence telemetry locally.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=prod,host.name=medelynas
