  "components": {
    "schemas": {
      "ArtifactDto": {
        "required": [
          "id",
          "kind",
          "url",
          "title",
          "linkedProjectIds",
          "linkedEngagementIds",
          "linkedSkills"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "kind": {
            "$ref": "#/components/schemas/ArtifactKind"
          },
          "url": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "producedOn": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "archived": {
            "type": "boolean"
          },
          "linkedProjectIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "linkedEngagementIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "linkedSkills": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ArtifactSkillLinkDto"
            }
          }
        }
      },
      "ArtifactKind": {
        "type": "integer"
      },
      "ArtifactRole": {
        "type": "integer"
      },
      "ArtifactSkillLinkDto": {
        "required": [
          "skillId",
          "role"
        ],
        "type": "object",
        "properties": {
          "skillId": {
            "type": "string",
            "format": "uuid"
          },
          "role": {
            "$ref": "#/components/schemas/ArtifactRole"
          }
        }
      },
      "CaptionResponse": {
        "required": [
          "caption"
        ],
        "type": "object",
        "properties": {
          "caption": {
            "type": "string"
          }
        }
      },
      "ChatRequest": {
        "required": [
          "prompt"
        ],
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string"
          }
        }
      },
      "ChatResponse": {
        "required": [
          "reply"
        ],
        "type": "object",
        "properties": {
          "reply": {
            "type": "string"
          }
        }
      },
      "Detection": {
        "required": [
          "x1",
          "y1",
          "x2",
          "y2",
          "label"
        ],
        "type": "object",
        "properties": {
          "x1": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "y1": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "x2": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "y2": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "label": {
            "type": "string"
          }
        }
      },
      "DetectionResponse": {
        "required": [
          "items"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Detection"
            }
          }
        }
      },
      "Engagement": {
        "required": [
          "id",
          "kind",
          "institution",
          "titles",
          "start",
          "skills",
          "projects"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "kind": {
            "$ref": "#/components/schemas/EngagementKind"
          },
          "institution": {
            "type": "string"
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "titles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TitleEpochDto"
            }
          },
          "start": {
            "type": "string",
            "format": "date"
          },
          "end": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "summary": {
            "type": [
              "null",
              "string"
            ]
          },
          "location": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Location"
              }
            ]
          },
          "skills": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Skill"
            }
          },
          "projects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Project"
            }
          }
        }
      },
      "EngagementKind": {
        "type": "integer"
      },
      "ExperienceDto": {
        "required": [
          "id",
          "kind",
          "title",
          "occurredOn",
          "skillIds"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "kind": {
            "$ref": "#/components/schemas/ExperienceKind"
          },
          "title": {
            "type": "string"
          },
          "occurredOn": {
            "type": "string",
            "format": "date"
          },
          "endDate": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "engagementId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "projectId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "skillIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "location": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Location"
              }
            ]
          }
        }
      },
      "ExperienceKind": {
        "type": "integer"
      },
      "GoalDto": {
        "required": [
          "id",
          "targetMaturity",
          "motivation",
          "status",
          "progress"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "skillId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "targetMaturity": {
            "$ref": "#/components/schemas/Maturity"
          },
          "deadline": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "motivation": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/GoalStatus"
          },
          "resolvedAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "resolutionReason": {
            "type": [
              "null",
              "string"
            ]
          },
          "evidenceArtifactId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "progress": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GoalProgressEntryDto"
            }
          }
        }
      },
      "GoalProgressEntryDto": {
        "required": [
          "recordedAt",
          "note"
        ],
        "type": "object",
        "properties": {
          "recordedAt": {
            "type": "string",
            "format": "date-time"
          },
          "note": {
            "type": "string"
          },
          "linkedEventId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          }
        }
      },
      "GoalStatus": {
        "type": "integer"
      },
      "IFormFile": {
        "type": "string",
        "format": "binary"
      },
      "Intensity": {
        "type": "integer"
      },
      "Location": {
        "required": [
          "kind",
          "city",
          "country"
        ],
        "type": "object",
        "properties": {
          "kind": {
            "$ref": "#/components/schemas/LocationKind"
          },
          "city": {
