          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "$ref": "#/components/schemas/SkillCategory"
          }
        }
      },
      "SkillCategory": {
        "type": "integer"
      },
      "SkillContextKind": {
        "type": "integer"
      },
      "SkillMaturityPointDto": {
        "required": [
          "occurredOn",
          "maturity"
        ],
        "type": "object",
        "properties": {
          "occurredOn": {
            "type": "string",
            "format": "date"
          },
          "maturity": {
            "$ref": "#/components/schemas/Maturity"
          },
          "reason": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "SkillMaturityResponse": {
        "required": [
          "skillId",
          "current",
          "trajectory"
        ],
        "type": "object",
        "properties": {
          "skillId": {
            "type": "string",
            "format": "uuid"
          },
          "current": {
            "$ref": "#/components/schemas/Maturity"
          },
          "trajectory": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SkillMaturityPointDto"
            }
          }
        }
      },
      "SkillRelatedEntry": {
        "required": [
          "skillId",
          "name",
          "count"
        ],
        "type": "object",
        "properties": {
          "skillId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "count": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "firstSeen": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "lastSeen": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          }
        }
      },
      "SkillRelatedResponse": {
        "required": [
          "skillId",
          "related"
