  "components": {
    "schemas": {
      "Engagement": {
        "required": [
          "id",
          "kind",
          "institution",
          "titles",
          "start",
          "skills",
          "projects"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "kind": {
            "$ref": "#/components/schemas/EngagementKind"
          },
          "institution": {
            "type": "string"
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "titles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TitleEpochDto"
            }
          },
          "start": {
            "type": "string",
            "format": "date"
          },
          "end": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "summary": {
            "type": [
              "null",
              "string"
            ]
          },
          "location": {
