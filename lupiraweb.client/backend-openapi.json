            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "contextLabel": {
            "type": [
              "null",
              "string"
            ]
          },
          "intensity": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Intensity"
              }
            ]
          },
          "maturity": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Maturity"
              }
            ]
          },
          "otherSkillId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "note": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "SkillTimelineResponse": {
        "required": [
          "skillId",
          "name",
          "entries"
        ],
        "type": "object",
        "properties": {
          "skillId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SkillTimelineEntryDto"
            }
          }
        }
      },
      "TitleEpochDto": {
        "required": [
          "titleId",
          "text",
          "from"
        ],
        "type": "object",
        "properties": {
          "titleId": {
            "type": "string",
            "format": "uuid"
          },
          "text": {
            "type": "string"
          },
          "from": {
            "type": "string",
            "format": "date"
          },
          "to": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          }
        }
      }
    }
  },
  "tags": [
