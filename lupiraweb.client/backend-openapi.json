        "type": "object",
        "properties": {
          "skillId": {
            "type": "string",
            "format": "uuid"
          },
          "related": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SkillRelatedEntry"
            }
          }
        }
      },
      "SkillTimelineEntryDto": {
        "required": [
          "kind",
          "occurredOn"
        ],
        "type": "object",
        "properties": {
          "kind": {
            "type": "string"
          },
          "occurredOn": {
            "type": "string",
            "format": "date"
          },
          "contextKind": {
            "oneOf": [
