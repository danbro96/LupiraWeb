              "string"
            ],
            "format": "date"
          },
          "archived": {
            "type": "boolean"
          },
          "linkedProjectIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "linkedEngagementIds": {
            "type": "array",
